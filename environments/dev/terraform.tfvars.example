region             = "us-east-1"
project            = "catalog"
vpc_cidr           = "10.10.0.0/16"
availability_zones = ["us-east-1a", "us-east-1b", "us-east-1c"]

# Image tags — bump from CI on each deploy. The "bootstrap" tag is the
# placeholder image you push once after first apply.
products_api_image_tag = "bootstrap"
image_resizer_tag      = "bootstrap"

# null = ALB serves HTTP only (acceptable for dev).
# Provide an ACM cert ARN to enable HTTPS + the HTTP→HTTPS redirect.
certificate_arn = null

# Set to your email to subscribe to alerts. AWS sends a confirmation link.
alarm_email = null

additional_tags = {
  Owner = "platform"
}
