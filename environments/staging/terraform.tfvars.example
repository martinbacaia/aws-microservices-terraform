region             = "us-east-1"
project            = "catalog"
vpc_cidr           = "10.20.0.0/16"
availability_zones = ["us-east-1a", "us-east-1b", "us-east-1c"]

products_api_image_tag = "bootstrap"
image_resizer_tag      = "bootstrap"

# Required for staging — HTTPS is mandatory.
certificate_arn = "arn:aws:acm:us-east-1:123456789012:certificate/CHANGE-ME"

alarm_email = "platform-alerts@example.com"

additional_tags = {
  Owner = "platform"
}
